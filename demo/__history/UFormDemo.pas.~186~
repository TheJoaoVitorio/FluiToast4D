procedure TFormDemo.FormCreate(Sender: TObject);
begin

  with fileOdlgImage do
  begin
    FileTypes.Clear;

      with FileTypes.Add do
      begin
        DisplayName := 'Imagens';
        FileMask := '*.jpg;*.jpeg;*.png;*.bmp;*.gif;*.tif;*.tiff';
      end;

      DefaultExtension := 'jpg';
  end;

end;

procedure TFormDemo.imgForToastClick(Sender: TObject);
