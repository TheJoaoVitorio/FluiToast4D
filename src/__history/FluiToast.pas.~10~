unit FluiToast;

interface

uses
  System.Classes, Vcl.Graphics, FluiToast.Types, FluiToast.View, FluiToast.Manager;

type
  [ComponentPlatformsAttribute(pidWin32 or pidWin64)]
  TFluiToast = class(TComponent, IFluiToast)
  private
    FTitle: string;
    FMessage: string;
    FType: TFluiToastType;
    FPosition: TFluiToastPosition;
    FDuration: Integer;
    FOnClick: TFluiToastAction;
    FRounding: Integer;
    FBackgroundColor: TColor;
    FTitleColor: TColor;
    FMessageColor: TColor;
    FBorderColor: TColor;
    FFontName: string;
  protected
    function Title(const AValue: string): IFluiToast;
    function Message(const AValue: string): IFluiToast;
    function ToastType(const AValue: TFluiToastType): IFluiToast;
    function Position(const AValue: TFluiToastPosition): IFluiToast;
    function Duration(const AValue: Integer): IFluiToast;
    function OnClick(const AValue: TFluiToastAction): IFluiToast;
    function BackgroundColor(const AValue: TColor): IFluiToast;
    function TitleColor(const AValue: TColor): IFluiToast;
    function MessageColor(const AValue: TColor): IFluiToast;
    function BorderColor(const AValue: TColor): IFluiToast;
    function FontName(const AValue: string): IFluiToast;
    function Rounding(const AValue: Integer): IFluiToast;
    function Clone: IFluiToast;
    procedure Show;
  public
    constructor Create(AOwner: TComponent); override;
    class function New: IFluiToast;
  published
    property DefaultTitle: string read FTitle write FTitle;
    property DefaultMessage: string read FMessage write FMessage;
    property DefaultType: TFluiToastType read FType write FType default ftCustom;
    property DefaultPosition: TFluiToastPosition read FPosition write FPosition default ftpBottomRight;
    property DefaultDuration: Integer read FDuration write FDuration default 3000;
    property DefaultRounding: Integer read FRounding write FRounding default 25;
    property DefaultBackgroundColor: TColor read FBackgroundColor write FBackgroundColor default clWhite;
    property DefaultTitleColor: TColor read FTitleColor write FTitleColor default COLOR_TEXT_TITLE;
    property DefaultMessageColor: TColor read FMessageColor write FMessageColor default COLOR_TEXT_MESSAGE;
    property DefaultBorderColor: TColor read FBorderColor write FBorderColor default COLOR_BORDER_DEFAULT;
    property DefaultFontName: string read FFontName write FFontName;
  end;

implementation

{ TFluiToast }

constructor TFluiToast.Create(AOwner: TComponent);
begin
  inherited Create(AOwner);
  FType := ftCustom;
  FPosition := ftpBottomRight;
  FDuration := 3000;
  FRounding := 38;
  FBackgroundColor := clWhite;
  FTitleColor := COLOR_TEXT_TITLE;
  FMessageColor := COLOR_TEXT_MESSAGE;
  FBorderColor := COLOR_BORDER_DEFAULT;
  FFontName := 'Inter';
end;

function TFluiToast.BackgroundColor(const AValue: TColor): IFluiToast;
begin
  FBackgroundColor := AValue;
  FType := ftCustom;
  Result := Self;
end;

function TFluiToast.BorderColor(const AValue: TColor): IFluiToast;
begin
  FBorderColor := AValue;
  FType := ftCustom;
  Result := Self;
end;

function TFluiToast.Duration(const AValue: Integer): IFluiToast;
begin
  FDuration := AValue;
  Result := Self;
end;

function TFluiToast.FontName(const AValue: string): IFluiToast;
begin
  FFontName := AValue;
  Result := Self;
end;

function TFluiToast.Message(const AValue: string): IFluiToast;
begin
  FMessage := AValue;
  Result := Self;
end;

function TFluiToast.MessageColor(const AValue: TColor): IFluiToast;
begin
  FMessageColor := AValue;
  FType := ftCustom;
  Result := Self;
end;

class function TFluiToast.New: IFluiToast;
begin
  Result := TFluiToast.Create(nil);
end;

function TFluiToast.Clone: IFluiToast;
var
  LClone: TFluiToast;
begin
  LClone := TFluiToast.Create(nil);
  LClone.FTitle := Self.FTitle;
  LClone.FMessage := Self.FMessage;
  LClone.FType := Self.FType;
  LClone.FPosition := Self.FPosition;
  LClone.FDuration := Self.FDuration;
  LClone.FOnClick := Self.FOnClick;
  LClone.FRounding := Self.FRounding;
  LClone.FBackgroundColor := Self.FBackgroundColor;
  LClone.FTitleColor := Self.FTitleColor;
  LClone.FMessageColor := Self.FMessageColor;
  LClone.FBorderColor := Self.FBorderColor;
  LClone.FFontName := Self.FFontName;
  Result := LClone;
end;

function TFluiToast.OnClick(const AValue: TFluiToastAction): IFluiToast;
begin
  FOnClick := AValue;
  Result := Self;
end;

function TFluiToast.Position(const AValue: TFluiToastPosition): IFluiToast;
begin
  FPosition := AValue;
  Result := Self;
end;

function TFluiToast.Rounding(const AValue: Integer): IFluiToast;
begin
  FRounding := AValue;
  FType := ftCustom;
  Result := Self;
end;

procedure TFluiToast.Show;
var
  LView: TFluiToastView;
begin
  LView := TFluiToastView.Create(nil);
  LView.Title := FTitle;
  LView.Message := FMessage;
  LView.ToastType := FType;
  LView.Duration := FDuration;
  LView.OnToastClick := FOnClick;
  LView.Rounding := FRounding;
  LView.BackgroundColor := FBackgroundColor;
  LView.TitleColor := FTitleColor;
  LView.MessageColor := FMessageColor;
  LView.BorderColor := FBorderColor;
  LView.FontName := FFontName;
  
  TFluiToastManager.GetInstance.ShowToast(LView, FPosition);
end;

function TFluiToast.Title(const AValue: string): IFluiToast;
begin
  FTitle := AValue;
  Result := Self;
end;

function TFluiToast.TitleColor(const AValue: TColor): IFluiToast;
begin
  FTitleColor := AValue;
  FType := ftCustom;
  Result := Self;
end;

function TFluiToast.ToastType(const AValue: TFluiToastType): IFluiToast;
begin
  FType := AValue;
  Result := Self;
end;

end.
